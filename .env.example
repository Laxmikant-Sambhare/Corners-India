# ── Shopify Storefront API ───────────────────────────────────────────────────
#
# These variables wire the site to your live Shopify store.
# Without DOMAIN + TOKEN the site renders static mock data (no API calls).
#
# HOW TO GET THESE VALUES
# ───────────────────────
# 1. Shopify Admin → Settings → Apps and sales channels → Develop apps
# 2. Click "Create an app" (or open an existing one)
# 3. Configuration tab → Storefront API access scopes — enable:
#      ✅ unauthenticated_read_product_listings
#      ✅ unauthenticated_read_product_tags
#      ✅ unauthenticated_read_product_inventory
#      ✅ unauthenticated_read_customers (for login / orders)
#      ✅ unauthenticated_write_customers (for register / newsletter)
# 4. Save → API credentials tab → copy "Storefront API access token"

# Your store's .myshopify.com domain (no https://)
VITE_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Storefront API public access token
VITE_SHOPIFY_STOREFRONT_TOKEN=your-storefront-access-token

# ── Shopify Customer Account API (New Customer Accounts / OAuth) ─────────────
#
# Required for login via OAuth PKCE flow (passwordless / OTP).
#
# HOW TO GET THESE VALUES
# ───────────────────────
# Shopify Admin → Settings → Customer accounts → Headless → manage
# Copy the "Client ID" shown there.
#
# The numeric shop ID is visible in any Shopify Admin URL, e.g.:
#   https://admin.shopify.com/store/your-store/... → use the store handle
#   OR check Admin → Settings → General → scroll to the bottom for "Store ID"

# Numeric Shopify shop ID (used to build the customer portal URL)
VITE_SHOPIFY_SHOP_ID=your-numeric-shop-id

# OAuth client ID from the Headless channel settings
VITE_SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_ID=your-client-id

# ── Shopify Admin API (import scripts + newsletter subscribe) ────────────────
#
# Required for: shopify/upload-files.mjs, shopify/set-file-metafields.mjs,
#               netlify/functions/newsletter-subscribe.mjs
#
# Your Dev Dashboard app needs scope: write_customers (or read_customers + write_customers)
# Install the app on the store and add the same credentials to Netlify env vars.
# Option A — Dev Dashboard app (recommended): Client ID + Secret from Settings
SHOPIFY_ADMIN_CLIENT_ID=your-client-id
SHOPIFY_ADMIN_CLIENT_SECRET=shpss_your-client-secret
# Option B — legacy custom app direct token
# SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_your-admin-token
